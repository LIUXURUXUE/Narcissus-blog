---
import MainGridLayout from '../layouts/MainGridLayout.astro';
import { getSortedPosts } from '../utils/content-utils';
import { getPostUrlBySlug } from '../utils/url-utils';

const allPosts = await getSortedPosts();
const featuredPost = allPosts[0];
const recentPosts = allPosts.slice(0, 6);
---

<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Narcissus Blog</title>
	</head>
	<body>
		<MainGridLayout>
			<div class="container mx-auto px-4 py-8">
				<h1 class="text-4xl font-bold mb-8">欢迎来到我的博客</h1>

				{featuredPost && (
					<section class="mb-12">
						<h2 class="text-2xl font-semibold mb-4">精选文章</h2>
						<article class="bg-gradient-to-r from-purple-500 to-pink-500 rounded-lg p-6 text-white shadow-lg">
							<a href={getPostUrlBySlug(featuredPost.slug)} class="block hover:opacity-90 transition-opacity">
								<h3 class="text-2xl font-bold mb-2">{featuredPost.data.title}</h3>
								<p class="opacity-90 mb-4">{featuredPost.data.description}</p>
								<time class="text-sm opacity-75">{new Date(featuredPost.data.published).toLocaleDateString('zh-CN')}</time>
							</a>
						</article>
					</section>
				)}

				<section>
					<h2 class="text-2xl font-semibold mb-4">最新文章</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					{recentPosts.map(post => (
						<article class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
							<a href={getPostUrlBySlug(post.slug)} class="block">
								{post.data.image && (
									<img
										src={post.data.image}
										alt={post.data.title}
										class="w-full h-48 object-cover"
									/>
								)}
								<div class="p-6">
									<h3 class="text-xl font-semibold mb-2 line-clamp-2">{post.data.title}</h3>
									<p class="text-gray-600 dark:text-gray-300 mb-4 line-clamp-3">
										{post.data.description}
									</p>
									<time class="text-sm text-gray-500 dark:text-gray-400">
										{new Date(post.data.published).toLocaleDateString('zh-CN')}
									</time>
								</div>
							</a>
						</article>
					))}
					</div>
				</section>

				{allPosts.length > 6 && (
					<div class="text-center mt-8">
						<a href="/page/1/" class="inline-block bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 transition-colors">
							查看更多文章
						</a>
					</div>
				)}
			</div>
		</MainGridLayout>
	</body>
</html>
